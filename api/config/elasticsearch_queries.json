{
    "daily_proofreader_hits": {
      "index": "emdata4*_dvid_activity-*",
      "query": {
        "_source": [
          "user",
          "uri",
          "duration"
        ],
        "query": {
          "bool": {
            "filter": [],
            "must": [
              {
                "match_all": {}
              },
              {
                "range": {
                  "@timestamp": {
                    "gte": "now-1d"
                  }
                }
              },
              {
                "bool": {
                  "minimum_should_match": 1,
                  "should": [
                    {
                      "match_phrase": {
                        "uri": "cleave"
                      }
                    },
                    {
                      "match_phrase": {
                        "uri": "merge"
                      }
                    },
                    {
                      "match_phrase": {
                        "uri": "split-supervoxel"
                      }
                    }
                  ]
                }
              }
            ],
            "must_not": [],
            "should": []
          }
        }
      }
    },
    "dvid_avg_hits": {
      "index": "emdata*_dvid_activity-*",
      "query": {
        "aggs": {
          "1": {
            "avg": {
              "field": "duration"
            }
          }
        },
        "docvalue_fields": [
          {
            "field": "@timestamp",
            "format": "date_time"
          }
        ],
        "query": {
          "bool": {
            "must": [
              {
                "range": {
                  "@timestamp": {
                    "gte": "now-1m"
                  }
                }
              }
            ]
          }
        },
        "size": 0
      }
    },
    "dvid_client_count_summary": {
      "index": "emdata*_dvid_activity-*",
      "query": {
        "_source": {
          "excludes": []
        },
        "aggs": {
          "2": {
            "terms": {
              "field": "client.keyword",
              "order": {
                "_count": "desc"
              },
              "size": 100
            }
          }
        },
        "docvalue_fields": [
          {
            "field": "@timestamp",
            "format": "date_time"
          }
        ],
        "query": {
          "bool": {
            "filter": [],
            "must": [
              {
                "match_all": {}
              },
              {
                "range": {
                  "@timestamp": {
                    "gte": "now-1m"
                  }
                }
              }
            ],
            "must_not": [],
            "should": []
          }
        },
        "script_fields": {},
        "size": 0,
        "stored_fields": [
          "*"
        ]
      }
    },
    "dvid_combined_minute_summary": {
      "index": "emdata*_dvid_activity-*",
      "query": {
        "_source": {
          "excludes": []
        },
        "aggs": {
          "2": {
            "aggs": {
              "3": {
                "aggs": {
                  "4": {
                    "aggs": {
                      "5": {
                        "aggs": {

                                  "field": "bytes_in"
                                }
                              },
                              "11": {
                                "sum": {
                                  "field": "bytes_out"
                                }
                              },
                              "12": {
                                "percentiles": {
                                  "field": "duration",
                                  "keyed": false,
                                  "percents": [
                                    99
                                  ]
                                }
                              },
                              "7": {
                                "max": {
                                  "field": "duration"
                                }
                              },
                              "8": {
                                "min": {
                                  "field": "duration"
                                }
                              },
                              "9": {
                                "avg": {
                                  "field": "duration"
                                }
                              }
                            },
                            "terms": {
                              "field": "port.keyword",
                              "order": {
                                "_count": "desc"
                              },
                              "size": 10
                            }
                          }
                        },
                        "terms": {
                          "field": "server.keyword",
                          "order": {
                            "_count": "desc"
                          },
                          "size": 10
                        }
                      }
                    },
                    "terms": {
                      "field": "method.keyword",
                      "order": {
                        "_count": "desc"
                      },
                      "size": 10
                    }
                  }
                },
                "terms": {
                  "field": "client.keyword",
                  "order": {
                    "_count": "desc"
                  },
                  "size": 100
                }
              }
            },
            "terms": {
              "field": "user.keyword",
              "order": {
                "_count": "desc"
              },
              "size": 100
            }
          }
        },
        "docvalue_fields": [
          {
            "field": "@timestamp",
            "format": "date_time"
          }
        ],
        "query": {
          "bool": {
            "filter": [],
            "must": [
              {
                "match_all": {}
              },
              {
                "range": {
                  "@timestamp": {
                    "gte": "now-1m"
                  }
                }
              }
            ],
            "must_not": [],
            "should": []
          }
        },
        "script_fields": {},
        "size": 0,
        "stored_fields": [
          "*"
        ]
      }
    },
    "neutu_date": {
      "index": "neutu_app-*",
      "query": {
        "docvalue_fields": [
          {
            "field": "@timestamp",
            "format": "date"
          }
        ],
        "query": {
          "bool": {
            "minimum_should_match": 2,
            "must": [
              {
                "term": {
                  "@timestamp": {
                    "value": "2019-10-11"
                  }
                }
              }
            ],
            "should": [
              {
                "match": {
                  "description": "BEGIN"
                }
              },
              {
                "match": {
                  "description": "END"
                }
              },
              {
                "match": {
                  "description": "NeuTu"
                }
              }
            ]
          }
        }
      }
    },
    "standard_metrics": {
